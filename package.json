{
  "name": "motoworkshop-saas",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test:ci",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "3.3.3",
    "typescript": "5.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.4",
  "pnpm": {
    "overrides": {
      "@types/react": "19",
      "@types/react-dom": "19",
      "qs": ">=6.15.2",
      "js-yaml": ">=4.2.0",
      "postcss": ">=8.5.10",
      "tmp": ">=0.2.6",
      "ajv@>=7.0.0 <8.18.0": "8.18.0",
      "tar@>=7.0.0 <7.5.16": "7.5.16",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "multer@>=2.0.0 <2.2.0": "2.2.0",
      "uuid@>=11.0.0 <11.1.1": "11.1.1",
      "glob@>=10.2.0 <10.5.0": "10.5.0",
      "ws@>=8.0.0 <8.21.0": "8.21.0",
      "cookie@<0.7.0": "0.7.2"
    }
  }
}
