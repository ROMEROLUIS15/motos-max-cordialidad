# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/motoworkshop_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption
ENCRYPTION_KEY="change-me-to-a-64-char-hex-string-for-aes256gcm-encryption-key"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# AI Providers
DEEPSEEK_API_KEY=""
GROQ_API_KEY=""

# Sentry (optional)
SENTRY_DSN=""

# App
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed CORS origins in production (e.g. https://app.yourdomain.com)
# If empty in production, ALL origins are blocked. Required when NODE_ENV=production.
ALLOWED_ORIGINS="https://app.yourdomain.com"

# Agents microservice (Fase 2C)
# NestJS → Python: where the agents service lives (admin WhatsApp routing).
AGENTS_BASE_URL="http://localhost:8000"
# Python → NestJS: only needed inside the agents service (Docker overrides it).
API_BASE_URL="http://localhost:3001"
# Admin conversation window kept in Redis (seconds). Default 2h.
ADMIN_SESSION_TTL_SECONDS=7200
# TTL of the service-to-service JWT the agents mint to call the API. Default 5m.
SERVICE_TOKEN_TTL_SECONDS=300
# Timezone for the agents' cron jobs (weekly/monthly/stock).
TZ="America/Bogota"
# Disable the in-process scheduler (e.g. for a second agents instance).
SCHEDULER_ENABLED=true
