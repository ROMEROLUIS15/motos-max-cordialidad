# ================================================
# Motos Max Cordialidad — Local Dev Environment
# ================================================
# Copia este archivo a .env.local y llena los valores.
# NUNCA commitear .env.local — está en .gitignore
# ================================================

# ── DATABASE ──────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5433/motoworkshop_dev"
# Prod (Neon): DATABASE_URL=""

# ── REDIS ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── AUTH & SECURITY ───────────────────────────────
JWT_SECRET="change-me-to-a-secure-random-string-at-least-64-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
ENCRYPTION_KEY="change-me-to-a-64-char-hex-string-for-aes256gcm-encryption-key"

# ── CLOUDFLARE R2 (STORAGE) ───────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ── WHATSAPP (Meta Cloud API) ─────────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
# Opcional: plantilla utility aprobada (1 parametro de body) para mensajes fuera de la ventana de 24h
WHATSAPP_UTILITY_TEMPLATE=""
# Opcional: version de Graph API (default v21.0)
WHATSAPP_API_VERSION=""

# ── AI PROVIDERS ──────────────────────────────────
DEEPSEEK_API_KEY=""
GROQ_API_KEY=""
# Opcional: modelo de Groq (default openai/gpt-oss-120b). Solo se cambia si Groq
# deprecia el modelo; ver la lista en https://console.groq.com/docs/models
GROQ_MODEL=""

# ── MONITORING (Sentry) — opcional ────────────────
SENTRY_DSN=""

# ── APPLICATION ───────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── EMAIL — Resend (password reset & notificaciones) ──
RESEND_API_KEY=""
SMTP_FROM=""
FRONTEND_URL="http://localhost:3000"

# ── MICROSERVICES (Agents) ────────────────────────
AGENTS_BASE_URL="http://localhost:8000"
API_BASE_URL="http://localhost:3001"
ADMIN_SESSION_TTL_SECONDS=7200
SERVICE_TOKEN_TTL_SECONDS=300
TZ="America/Bogota"
SCHEDULER_ENABLED=true

# ── FRONTEND (Next.js) ────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── DEPLOYMENT & INFRASTRUCTURE ───────────────────
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
RENDER_API_KEY=""
