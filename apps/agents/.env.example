# Database connection for agents (same as API)
DATABASE_URL="postgresql://user:password@localhost:5432/motoworkshop_dev"

# Redis connection for sessions and queues
REDIS_URL="redis://localhost:6379"

# API connection for agents to call NestJS API
API_BASE_URL="http://localhost:3001"
API_SERVICE_TOKEN="change-me-to-service-token-from-api"

# AI Providers
DEEPSEEK_API_KEY=""
GROQ_API_KEY=""
# Optional: Groq model (default openai/gpt-oss-120b). Only change it if Groq
# deprecates the model; see https://console.groq.com/docs/models
GROQ_MODEL=""

# WhatsApp configuration (for agent responses)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# Cloudflare R2 for storing generated reports
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Sentry for error tracking (optional)
SENTRY_DSN=""

# Application settings
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Timezone for scheduler jobs
TZ="America/Bogota"

# Scheduler configuration
SCHEDULER_ENABLED=true

# Admin session configuration
ADMIN_SESSION_TTL_SECONDS=7200
SERVICE_TOKEN_TTL_SECONDS=300

# Email configuration for notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Frontend URL for links in notifications
FRONTEND_URL="http://localhost:3000"