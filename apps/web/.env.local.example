# Frontend (Next.js) — copy to apps/web/.env.local and fill in.
# Solo las NEXT_PUBLIC_* llegan al navegador; nunca pongas secretos ahí.

# URL del backend (NestJS). En local apunta al API local; en prod, a Render.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Sentry (opcional). DSN público para errores del cliente.
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry source-map upload en build (opcional; CI/Vercel). NO son públicas.
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
