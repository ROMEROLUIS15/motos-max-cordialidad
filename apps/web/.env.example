# API backend — apunta al backend en vivo (Render) para desarrollo local del frontend.
# Para usar API local: cambia a http://localhost:3000 y levanta `pnpm dev:api`.
NEXT_PUBLIC_API_URL="https://motoworkshop-api.onrender.com"
# NEXT_PUBLIC_API_URL="http://localhost:3001"

# Sentry (proyecto Next.js) — cliente y server del frontend
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""

# Environment
NODE_ENV=development