# Database (Neon PostgreSQL)
# Development — Docker Postgres local
DATABASE_URL="postgresql://user:password@localhost:5432/motoworkshop_dev"

# Production — Neon (usar en GitHub Secrets, no aquí)
# DATABASE_URL=""

# Redis
REDIS_URL="redis://localhost:6379"
# Production: usar la URL interna del Key Value de Render (dashboard, no aquí)

# JWT
JWT_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption
ENCRYPTION_KEY="change-me-to-a-64-char-hex-string-for-aes256gcm-encryption-key"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
# Opcional: plantilla utility aprobada (1 parametro de body) para mensajes fuera de la ventana de 24h
WHATSAPP_UTILITY_TEMPLATE=""
# Opcional: version de Graph API (default v21.0)
WHATSAPP_API_VERSION=""

# AI Providers
DEEPSEEK_API_KEY=""
GROQ_API_KEY=""
# Optional: Groq model (default openai/gpt-oss-120b). Only change it if Groq
# deprecates the model; see https://console.groq.com/docs/models
GROQ_MODEL=""

# Sentry (optional)
SENTRY_DSN=""

# App
PORT=3001
NODE_ENV=development


CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

RENDER_API_KEY=""

# Email (password reset) — Resend API
# Sin dominio verificado en Resend: SMTP_FROM debe ser "onboarding@resend.dev"
# y solo puede enviarse al email del dueño de la cuenta Resend.
RESEND_API_KEY=""
SMTP_FROM=""
FRONTEND_URL="http://localhost:3000"

# Seed: email + contraseña del OWNER real (si se omiten usa el owner demo owner@demo.com / Demo1234!)
OWNER_SEED_EMAIL=""
OWNER_SEED_PASSWORD=""


# CORS for production
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Agents microservice
AGENTS_BASE_URL="http://localhost:8000"
API_BASE_URL="http://localhost:3001"
ADMIN_SESSION_TTL_SECONDS=7200
SERVICE_TOKEN_TTL_SECONDS=300
TZ="America/Bogota"
SCHEDULER_ENABLED=true